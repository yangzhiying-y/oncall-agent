# Copy this file to .env, then replace the placeholder API key.
# Never commit the real .env file.

# DashScope / Alibaba Cloud
DASHSCOPE_API_KEY=replace-with-your-api-key
DASHSCOPE_MODEL=qwen-max
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4

# Application
DEBUG=false
HOST=0.0.0.0
PORT=9900
LOG_ENQUEUE=true
# Add the deployed web address here if the front end is hosted separately.
CORS_ALLOWED_ORIGINS=http://localhost:9900,http://127.0.0.1:9900

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# Milvus vector database
MILVUS_HOST=localhost
MILVUS_PORT=19530

# Knowledge retrieval
RAG_TOP_K=3
CHUNK_MAX_SIZE=800
CHUNK_OVERLAP=100

# Tencent Cloud CLS MCP Server (可选 — 使用腾讯云官方日志服务)
# 配置后自动启用，无需启动本地 cls_server.py
# 使用前确保已安装 Node.js (LTS) 并可通过 npx 访问
# 文档: https://cloud.tencent.com/document/product/614/118699
TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=
TENCENTCLOUD_REGION=ap-guangzhou

# MCP Servers（本地回退方案 — 未配置腾讯云密钥时使用）
MCP_CLS_TRANSPORT=streamable-http
MCP_CLS_URL=http://localhost:8003/mcp
MCP_MONITOR_TRANSPORT=streamable-http
MCP_MONITOR_URL=http://localhost:8004/mcp

# Optional AIOps integrations
PROMETHEUS_BASE_URL=http://127.0.0.1:9090
PROMETHEUS_REQUEST_TIMEOUT=10
